# ─────────────────────────────────────────────────────────────
# Seriouspreneur Python backend — environment configuration
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# App
ENV=dev                          # dev | prod
LOG_LEVEL=INFO
CORS_ORIGINS=*                   # comma-separated origins in prod, e.g. https://app.lovable.dev

# Auth — verify Supabase JWTs server-side (the user_id comes from the token, never the body)
AUTH_DISABLED=false              # true ONLY for local smoke tests without a real JWT

# Supabase (service role stays server-side only)
SUPABASE_URL=https://sijvpggsijwrvzfyjfrz.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=             # Supabase → Settings → API → JWT Secret (HS256)

# OpenRouter (single LLM gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=https://seriouspreneur.app    # sent as HTTP-Referer for OpenRouter analytics
OPENROUTER_APP_NAME=Seriouspreneur

# Model routing (override any of these without code changes)
MODEL_BULK=google/gemini-2.0-flash-exp:free      # parsing, outreach copy, high volume
MODEL_AGENT=deepseek/deepseek-chat               # strategy agent reasoning / tool use
MODEL_ANALYTICS=openai/gpt-4o-mini               # analytics + daily-plan JSON synthesis
BUDGET_USD_CAP=20                                # soft cap; calls refused past this

# Google APIs
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Messaging providers
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_SMS_TEMPLATE_ID=
GALLABOX_API_KEY=
GALLABOX_API_SECRET=
GALLABOX_CHANNEL_ID=

# RAG embeddings: auto (fastembed if installed, else hashing) | fastembed | hashing
EMBEDDER=auto

# Reddit pain-point miner (optional; miner skips if blank)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
